{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./cli/dist",
    "rootDir": "./",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": [
    "src/core/**/*",
    "src/services/ClaudeDetectionService.ts",
    "src/adapters/vscode/VSCodeLogger.ts",
    "cli/src/**/*",
    "cli/tests/**/*"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/components/**/*",
    "src/providers/**/*",
    "src/controllers/**/*"
  ]
}

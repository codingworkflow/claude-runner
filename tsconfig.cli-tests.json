{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./cli/dist/tests",
    "rootDir": "./",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["jest", "node"]
  },
  "include": [
    "cli/tests/**/*",
    "cli/src/**/*",
    "src/core/**/*",
    "src/services/ClaudeDetectionService.ts",
    "src/adapters/vscode/VSCodeLogger.ts"
  ],
  "exclude": [
    "src/components/**/*",
    "src/providers/**/*",
    "src/controllers/**/*"
  ]
}
